generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            String            @id @default(cuid())
  name          String
  sku           String            @unique
  currentStock  Int
  dailySalesAvg Float
  analyses      RestockAnalysis[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model RestockAnalysis {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  stockAtAnalysis Int
  salesVelocityAt Float
  urgencyScore    Float
  urgencyStatus   String
  analyzedAt      DateTime @default(now())
}
